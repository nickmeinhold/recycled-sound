{
  "functions": [
    {
      "source": "functions",
      "codebase": "vision",
      "predeploy": ["npm --prefix functions run build"]
    },
    {
      "source": "functions-clip",
      "codebase": "clip",
      "runtime": "python312"
    }
  ],
  "firestore": {
    "rules": "functions/src/firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {"port": 9099},
    "functions": {"port": 5001},
    "firestore": {"port": 8080},
    "storage": {"port": 9199},
    "ui": {"enabled": true}
  }
}
